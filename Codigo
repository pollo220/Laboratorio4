    printf("Iniciando sistema con LCD + RFID + BLE + RTC...\n");

    configurar_salidas();
    buzzer_init();

    i2c_init();
    lcd_init();

    ds1307_set_time(10, 0, 0);

    sistema_activo = 0;
    lcd_mostrar_bloqueado();

    ble_init();

    spi_bus_config_t buscfg = {
        .miso_io_num = PIN_MISO,
        .mosi_io_num = PIN_MOSI,
        .sclk_io_num = PIN_SCK,
        .quadwp_io_num = -1,
        .quadhd_io_num = -1
    };

    spi_device_interface_config_t devcfg = {
        .clock_speed_hz = 500000,
        .mode = 0,
        .spics_io_num = PIN_CS,
        .queue_size = 7
    };

    spi_bus_initialize(SPI_HOST_USED, &buscfg, SPI_DMA_CH_AUTO);
    spi_bus_add_device(SPI_HOST_USED, &devcfg, &rc522_spi);

    rc522_init();

    uint8_t version = rc522_read_reg(VersionReg);

    printf("Version RC522: 0x%02X\n", version);

    if (version == 0x00 || version == 0xFF)
    {
        printf("No se detecta el RC522. Revisa conexiones SPI.\n");

        lcd_clear();
        lcd_set_cursor(0, 0);
        lcd_print("Error RC522");

        lcd_set_cursor(1, 0);
        lcd_print("Revise cables");
    }
    else
    {
        printf("RC522 detectado correctamente.\n");
        printf("Acerque una tarjeta...\n");
    }

    while (1)
    {
        int64_t ahora_ms = esp_timer_get_time() / 1000;

        if (sistema_activo == 1)
        {
            gpio_set_level(LED_AZUL, 1);

            if (actualizar_lcd_ble == 1)
            {
                actualizar_lcd_ble = 0;
                lcd_mostrar_estado_activo();
                ultima_actualizacion_hora = ahora_ms;
            }

            if ((ahora_ms - ultima_actualizacion_hora) >= 1000)
            {
                ultima_actualizacion_hora = ahora_ms;
                lcd_mostrar_estado_activo();
            }
        }

        uint8_t tagType[2];
        uint8_t uid[5];

        if ((ahora_ms - ultima_lectura_rfid) > RFID_COOLDOWN_MS)
        {
            if (rc522_request(PICC_REQALL, tagType))
            {
                if (rc522_anticoll(uid))
                {
                    ultima_lectura_rfid = ahora_ms;

                    printf("Tarjeta detectada. UID: ");

                    for (int i = 0; i < 4; i++)
                    {
                        printf("%02X ", uid[i]);
                    }

                    printf("\n");

                    lcd_clear();
                    lcd_set_cursor(0, 0);
                    lcd_print("UID detectado");

                    lcd_set_cursor(1, 0);

                    char uid_text[17];
                    const char hex[] = "0123456789ABCDEF";

                    uid_text[0]  = hex[(uid[0] >> 4) & 0x0F];
                    uid_text[1]  = hex[uid[0] & 0x0F];
                    uid_text[2]  = ' ';
                    uid_text[3]  = hex[(uid[1] >> 4) & 0x0F];
                    uid_text[4]  = hex[uid[1] & 0x0F];
                    uid_text[5]  = ' ';
                    uid_text[6]  = hex[(uid[2] >> 4) & 0x0F];
                    uid_text[7]  = hex[uid[2] & 0x0F];
                    uid_text[8]  = ' ';
                    uid_text[9]  = hex[(uid[3] >> 4) & 0x0F];
                    uid_text[10] = hex[uid[3] & 0x0F];
                    uid_text[11] = '\0';

                    lcd_print(uid_text);

                    vTaskDelay(pdMS_TO_TICKS(700));

                    if (uid_es_autorizado(uid))
                    {
                        if (sistema_activo == 0)
                        {
                            acceso_concedido();
                        }
                        else
                        {
                            cerrar_sesion();
                        }
                    }
                    else
                    {
                        if (sistema_activo == 0)
                        {
                            acceso_denegado();
                        }
                        else
                        {
                            printf("UID no autorizado ignorado en estado activo\n");
                            lcd_mostrar_estado_activo();
                            gpio_set_level(LED_AZUL, 1);
                        }
                    }

                    vTaskDelay(pdMS_TO_TICKS(1500));
                }
            }
        }

        vTaskDelay(pdMS_TO_TICKS(200));
    }
}
