void lcd_set_cursor(uint8_t row, uint8_t col)
{
    if (row == 0)
        lcd_cmd(0x80 + col);
    else
        lcd_cmd(0xC0 + col);
}

void lcd_print(const char *str)
{
    while (*str)
    {
        lcd_data(*str++);
    }
}

void lcd_print_16(const char *str)
{
    char buffer[17];

    for (int i = 0; i < 16; i++)
    {
        if (str[i] != '\0')
            buffer[i] = str[i];
        else
            buffer[i] = ' ';
    }

    buffer[16] = '\0';
    lcd_print(buffer);
}

int bcd_to_dec(uint8_t val)
{
    return ((val >> 4) * 10) + (val & 0x0F);
}

uint8_t dec_to_bcd(int val)
{
    return ((val / 10) << 4) | (val % 10);
}

void poner_hora_default(char *buffer)
{
    buffer[0] = '0';
    buffer[1] = '0';
    buffer[2] = ':';
    buffer[3] = '0';
    buffer[4] = '0';
    buffer[5] = ':';
    buffer[6] = '0';
    buffer[7] = '0';
    buffer[8] = '\0';
}

void ds1307_set_time(int hour, int min, int sec)
{
    uint8_t data[4];

    data[0] = 0x00;
    data[1] = dec_to_bcd(sec);
    data[2] = dec_to_bcd(min);
    data[3] = dec_to_bcd(hour);

    i2c_master_write_to_device(I2C_PORT, DS1307_ADDR, data, 4, pdMS_TO_TICKS(100));
}

void ds1307_get_time(char *buffer)
{
    uint8_t reg = 0x00;
    uint8_t data[3] = {0};

    esp_err_t ret = i2c_master_write_read_device(
        I2C_PORT,
        DS1307_ADDR,
        &reg,
        1,
        data,
        3,
        pdMS_TO_TICKS(100)
    );

    if (ret != ESP_OK)
    {
        poner_hora_default(buffer);
        return;
    }

    int sec  = bcd_to_dec(data[0] & 0x7F);
    int min  = bcd_to_dec(data[1]);
    int hour = bcd_to_dec(data[2] & 0x3F);

    if (hour > 23 || min > 59 || sec > 59)
    {
        poner_hora_default(buffer);
        return;
    }

    buffer[0] = '0' + (hour / 10);
    buffer[1] = '0' + (hour % 10);
    buffer[2] = ':';
    buffer[3] = '0' + (min / 10);
    buffer[4] = '0' + (min % 10);
    buffer[5] = ':';
    buffer[6] = '0' + (sec / 10);
    buffer[7] = '0' + (sec % 10);
    buffer[8] = '\0';
}

